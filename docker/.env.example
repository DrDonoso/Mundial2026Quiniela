# ============================================================
# Mundial2026Over9000 — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# Database
POSTGRES_USER=mundial
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mundial2026
DATABASE_URL=postgresql+asyncpg://mundial:changeme@db:5432/mundial2026

# Auth
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Football Data API
FOOTBALL_API_KEY=your-api-key-from-football-data-org
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHANNEL_ID=your-channel-id

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# App
APP_ENV=production
